%3
T = mixedTransform(x);
disp(T)

function T = mixedTransform(x)
T = zeros(size(x));     
T(x < 0) = abs(x(x < 0));
T(x == 0) = x(x == 0);
T(x > 0) = 2*x(x > 0) + 1;
end
