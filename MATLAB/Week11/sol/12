%(a)
H ;

%(b)
H.RiskScore = H.age ./ H.ejection_fraction + H.serum_creatinine;

%(c)
index = H.RiskScore >= 4;
RiskScoreGroup = H(index, :);

%(d)
RiskScoreGroup(:, {'age', 'ejection_fraction', 'serum_creatinine', ...
    'RiskScore', 'DEATH_EVENT'})

%(e)
writetable(RiskScoreGroup, 'heart_risk_group.csv');
