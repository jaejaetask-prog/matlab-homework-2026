clear; clc; close all

% (a)
A = [ 9 -2 -1;
     -2  8 -3;
     -1 -3 10];

b = [15;
      7;
     11];

% (b)
I = A \ b

% (c)
detA = det(A)

if detA ~= 0
    disp('A is invertible.')
else
    disp('A is not invertible.')
end

% (d)
absI = abs(I)

% (e)
[max_abs_I, index] = max(absI);

disp('Largest absolute current = ')
disp(max_abs_I)

disp('Current number = ')
disp(index)
