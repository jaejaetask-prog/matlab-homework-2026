clear; clc; close all

x = -5:0.05:5;
y = -5:0.05:5;

[X,Y] = meshgrid(x,y);

%a
Z = sin(X.*Y) ./ (1 + X.^2 + Y.^2);

%b
figure(1)
mesh(X,Y,Z);
grid on
title("Mesh plot")

%c
figure(2)
contour(X,Y,Z,25);
grid on
title('Contour plot')

%d
maxZ = max(abs(Z(:)));

%e
idx = find(abs(Z) == maxZ);

[row,col] = ind2sub(size(Z), idx);

x_max = X(row,col);
y_max = Y(row,col);

disp('max |Z| = ')
disp(maxZ)

disp('x coordinate = ')
disp(x_max)

disp('y coordinate = ')
disp(y_max)
