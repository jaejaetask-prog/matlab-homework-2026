clear; clc; close all

n = [50, 100, 200, 400, 800, 1600];
T = [14, 19, 30, 51, 92, 170];

figure(1)

% (a)
subplot(1,3,1)
plot(n,T,'o-')
grid on
title('plot')
xlabel('n')
ylabel('T')

% (b)
subplot(1,3,2)
semilogx(n,T,'o-')
grid on
title('semilogx')
xlabel('n')
ylabel('T')

% (c)
subplot(1,3,3)
semilogy(n,T,'o-')
grid on
title('semilogy')
xlabel('n')
ylabel('T')
