clear;clc

t = 0:0.1:25;
y = exp(-0.15.*t).*cos(4.*t);

upper_env = exp(-0.15*t);
lower_env = -exp(-0.15*t);

figure(9);

%(a)
subplot(1,3,1);
plot(t,y);
title('(a)');

%(b)
subplot(1,3,2);
plot(t,upper_env);
hold on;
plot(t,lower_env);
hold off;
title('(b)');

%(c)
subplot(1,3,3);
semilogy(t,abs(y))
title('(c)');
