import sys
input = sys.stdin.readline

def odd_part(x):
    while x % 2 == 0:
        x //= 2
    return x

t = int(input())

for _ in range(t):
    n = int(input())
    a = list(map(int, input().split()))

    ok = True

    for i in range(1, n + 1):
        if odd_part(i) != odd_part(a[i - 1]):
            ok = False
            break

    print("YES" if ok else "NO")
